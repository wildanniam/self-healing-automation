# ============================================================
# SELF-HEALING TEST AUTOMATION — Environment Variables
# ============================================================
# Salin file ini menjadi .env lalu isi nilai yang sesuai.
# Jangan commit file .env ke repository!

# ------------------------------------------------------------
# OpenAI API — WAJIB untuk Phase 1-3 (Healing Engine)
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...your-api-key-here...

# Model yang digunakan (opsional, default: gpt-4o-mini)
# Pilihan: gpt-4o | gpt-4o-mini | gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Maksimum token untuk respons LLM (opsional, default: 500)
OPENAI_MAX_TOKENS=500

# Temperature LLM — 0 = deterministik (opsional, default: 0)
OPENAI_TEMPERATURE=0

# ------------------------------------------------------------
# Konfigurasi Self-Healing (opsional)
# ------------------------------------------------------------
# Jumlah maksimum percobaan ulang ke LLM jika validasi gagal (default: 3)
HEALING_MAX_RETRIES=3

# Batas karakter DOM yang dikirim ke LLM untuk efisiensi token (default: 8000)
HEALING_DOM_MAX_CHARS=8000

# ------------------------------------------------------------
# GitHub — WAJIB untuk Phase 4 (Auto-Patching & Pull Request)
# ------------------------------------------------------------
# Personal Access Token GitHub
# Cara buat: GitHub → Settings → Developer settings →
#            Personal access tokens → Fine-grained tokens
# Permission yang dibutuhkan:
#   - Contents: Read and write
#   - Pull requests: Read and write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Username atau org name pemilik repository
GITHUB_OWNER=wildanniam

# Nama repository (bukan URL penuh, hanya nama repo-nya)
GITHUB_REPO=self-healing

# Branch tujuan Pull Request (default: main)
GITHUB_BASE_BRANCH=main

# ------------------------------------------------------------
# Git Bot — untuk identitas commit (opsional, ada default)
# ------------------------------------------------------------
GIT_BOT_NAME=Self-Healing Bot
GIT_BOT_EMAIL=self-healing-bot@noreply.com
